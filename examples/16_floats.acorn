import "core:fmt"

// Float literals
main :: fn() -> int {
    // Note: Float arithmetic is currently converted to integers in output
    // This is a known limitation
    pi <- 3.0
    e <- 2.0
    
    fmt.print(pi)  // prints 3
    fmt.print(e)   // prints 2
    
    // Float addition (currently truncates to int)
    result <- pi + e
    fmt.print(result)  // prints 5
    
    return 0
}