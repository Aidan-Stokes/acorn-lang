import "core:fmt"

// Arithmetic expressions
main :: fn() -> int {
    a <- 10
    b <- 3
    
    fmt.print(a + b)   // 13
    fmt.print(a - b)   // 7
    fmt.print(a * b)   // 30
    fmt.print(a / b)   // 3
    fmt.print(a % b)   // 1
    
    result <- (a + b) * 2 - 5
    fmt.print(result)  // 21
    
    return 0
}