import "core:fmt"

// Logical operators
main :: fn() -> int {
    a <- true
    b <- false
    
    fmt.print(a && b)  // 0 (false)
    fmt.print(a || b)  // 1 (true)
    fmt.print(!a)      // 0 (false)
    fmt.print(!b)      // 1 (true)
    
    // Combined
    fmt.print(a && !b)  // 1 (true)
    
    return 0
}