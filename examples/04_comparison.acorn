import "core:fmt"

// Comparison operators
main :: fn() -> int {
    x <- 10
    y <- 20
    
    // Comparison operators return 1 (true) or 0 (false)
    fmt.print(x == y)  // 0
    fmt.print(x != y)  // 1
    fmt.print(x < y)   // 1
    fmt.print(x <= y)  // 1
    fmt.print(x > y)   // 0
    fmt.print(x >= y)  // 0
    
    return 0
}