import "core:fmt"

// Pointer types with ^ dereference syntax
main :: fn() -> int {
    // Integer pointer (int is usize_t)
    x: int <- 42
    y: ^int <- &x
    z: int <- y^
    fmt.print(x)  // prints 42
    fmt.print(z)  // prints 42

    // Float pointer
    f: f32 <- 3.14
    fp: ^f32 <- &f
    fd: f32 <- fp^
    fmt.print(f)   // prints 3.14
    fmt.print(fd)  // prints 3.14

    return 0
}