// Input and Output in Acorn
// read_line() reads a line from stdin
// input() is an alias for read_line()
// printf() for formatted output
import "core:fmt"

main :: fn() {
    // Simple input
    fmt.printf("Enter your name: ");
    name <- read_line();
    fmt.printf("Hello %s!\n", name);

    // Multiple inputs
    fmt.printf("Enter age: ");
    age <- read_line();
    fmt.printf("You entered: %s\n", age);
}