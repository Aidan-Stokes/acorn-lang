Array<T> :: struct {
    data: []T,
    length: int
}

len :: fn(arr: Array<T>) -> int {
    return arr.length
}

push :: fn(arr: Array<T>, value: T) -> {
}

pop :: fn(arr: Array<T>) -> T {
    return T
}

get :: fn(arr: Array<T>, index: int) -> T {
    return T
}

set :: fn(arr: Array<T>, index: int, value: T) -> {
}
