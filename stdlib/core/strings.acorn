_ :: fn(s: string) -> int { return 0 }
contains :: fn(s: string, substr: string) -> bool { return false }
starts_with :: fn(s: string, prefix: string) -> bool { return false }
ends_with :: fn(s: string, suffix: string) -> bool { return false }
index_of :: fn(s: string, substr: string) -> int { return -1 }