// Formatting utilities
print<T> :: fn(x: T) -> int where T: Showable { return 0 }
println<T> :: fn(x: T) -> int where T: Showable { return 0 }
printf :: fn(fmt: string) -> int { return 0 }
to_string<T> :: fn(x: T) -> string where T: Showable { return "" }
format<T> :: fn(x: T) -> string where T: Showable { return "" }